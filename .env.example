# Copy to .env and fill in. Used by Makefile and devbox CLI.
# Nothing in here should be a secret — keep secrets in AWS SSM Parameter Store.

# AWS region the devbox lives in
AWS_REGION=us-east-1

# Name of an existing AWS EC2 key pair (must exist in AWS_REGION)
KEY_NAME=devbox

# Path to the private key on this laptop (matches KEY_NAME)
SSH_PRIVATE_KEY=~/.ssh/id_ed25519

# Globally-unique S3 bucket name for restic backups
BACKUP_BUCKET=devbox-state-CHANGE-ME

# Your laptop's public IP in CIDR form (used to lock down SSH)
# Run: curl -s ifconfig.me  to find it
ALLOWED_SSH_CIDR=1.2.3.4/32
