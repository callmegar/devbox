# Copy to terraform.tfvars (which is git-ignored) and edit.

aws_region          = "us-east-1"
owner_tag           = "your-name"
instance_type       = "t3.xlarge"
key_name            = "devbox"               # must already exist in aws_region
allowed_ssh_cidr    = "1.2.3.4/32"           # `curl -s ifconfig.me` then add /32
root_volume_size_gb = 50
data_volume_size_gb = 100
backup_bucket_name  = "devbox-state-CHANGE-ME"  # must be globally unique
